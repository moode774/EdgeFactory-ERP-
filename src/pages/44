import React, { useState, useRef } from 'react';
import { Plus, Trash2, Printer, Play, Eye, X, ChevronDown, ChevronUp, Edit3, FileText } from 'lucide-react';
import { Product, WorkOrder, WorkOrderItem, MaterialRequest, Customer } from '../types';
// WorkOrderDB import removed
import { AutoCompleteInput } from '../components/AutoCompleteInput';
import { autoCompleteService } from '../services/AutoCompleteService';
import WorkOrdersSummaryPrint from '../components/manufacturing/WorkOrdersSummaryPrint';

interface Props {
    lang: string;
    products: Product[];
    customers: Customer[];
    workOrders: WorkOrder[];
    onSaveWorkOrder: (order: any) => void;
    onUpdateWorkOrder: (id: string, order: any) => void;
    onDeleteWorkOrder: (id: string) => void;
    onExecuteWorkOrder: (id: string) => void;
    onRefresh: () => void;
}

const ManufacturingPage = ({ lang, products, customers, workOrders, onSaveWorkOrder, onUpdateWorkOrder, onDeleteWorkOrder, onExecuteWorkOrder, onRefresh }: Props) => {
    const [showWOModal, setShowWOModal] = useState(false);
    const [showPrintPreview, setShowPrintPreview] = useState(false);
    const [showSummaryPrint, setShowSummaryPrint] = useState(false);
    const [selectedOrder, setSelectedOrder] = useState<WorkOrder | null>(null);
    const [expandedOrder, setExpandedOrder] = useState<string | null>(null);
    const [editingOrderId, setEditingOrderId] = useState<string | null>(null);
    const printRef = useRef<HTMLDivElement>(null);

    // Work Order Form State
    // Helper functions for ID generation
    const generateOrderNumber = () => {
        const nextNumber = workOrders.length + 1;
        return `P${String(nextNumber).padStart(5, '0')}`;
    };

    const generateJobOrderNumber = () => {
        const year = new Date().getFullYear().toString().slice(-2);
        const baseNumber = 64; // Starting from 25-00064
        let maxNumber = baseNumber - 1;

        workOrders.forEach(order => {
            if (order.jobOrderNumber) {
                const parts = order.jobOrderNumber.split('-');
                if (parts.length === 2 && parts[0] === year) {
                    const num = parseInt(parts[1], 10);
                    if (!isNaN(num) && num > maxNumber) {
                        maxNumber = num;
                    }
                }
            }
        });

        const nextNumber = maxNumber + 1;
        return `${year}-${String(nextNumber).padStart(5, '0')}`;
    };

    const [woForm, setWoForm] = useState<{
        orderNumber: string;
        jobOrderNumber: string;
        customerName: string;
        customerId: string;
        priority: 'normal' | 'high' | 'very_high' | 'urgent';
        startDate: string;
        endDate: string;
        items: WorkOrderItem[];
        materials: MaterialRequest[];
        notes: string;
    }>(() => {
        const today = new Date();
        const endDate = new Date();
        endDate.setDate(endDate.getDate() + 10);

        return {
            orderNumber: '',
            jobOrderNumber: '',
            customerName: '',
            customerId: '',
            priority: 'normal',
            startDate: today.toISOString().split('T')[0],
            endDate: endDate.toISOString().split('T')[0],
            items: [],
            materials: [],
            notes: ''
        };
    });

    const resetForm = () => {
        const today = new Date();
        const endDate = new Date();
        endDate.setDate(endDate.getDate() + 10);

        setWoForm({
            orderNumber: generateOrderNumber(),
            jobOrderNumber: generateJobOrderNumber(),
            customerName: '',
            customerId: '',
            priority: 'normal',
            startDate: today.toISOString().split('T')[0],
            endDate: endDate.toISOString().split('T')[0],
            items: [{
                id: `item-${Date.now()}`,
                itemName: '',
                quantity: 1,
                unit: 'قطعة',
                dimensions: { height: 0, length: 0, width: 0 },
                modelCode: '',
                paintColor: '',
                paintCode: '',
                glossPercentage: '',
                veneer: 'NO',
                notes: ''
            }],
            materials: [
                {
                    id: `mat-wood-${Date.now()}`,
                    productName: '',
                    quantity: 1,
                    unit: '',
                    category: 'wood',
                    isManual: true,
                    size: { width: 0, length: 0 }
                },
                {
                    id: `mat-hardware-${Date.now() + 1}`,
                    productName: '',
                    quantity: 1,
                    unit: '',
                    category: 'accessories',
                    isManual: true,
                    notes: ''
                }
            ],
            notes: ''
        });
    };

    const openNewOrderModal = () => {
        resetForm();
        setEditingOrderId(null);
        setWoForm(prev => ({
            ...prev,
            orderNumber: generateOrderNumber(),
            jobOrderNumber: generateJobOrderNumber()
        }));
        setShowWOModal(true);
    };

    // Open Edit Order Modal
    const openEditOrderModal = (order: WorkOrder) => {
        setEditingOrderId(order.id);
        setWoForm({
            orderNumber: order.orderNumber,
            jobOrderNumber: order.jobOrderNumber,
            customerName: order.customerName,
            customerId: order.customerId || '',
            priority: order.priority,
            startDate: order.startDate ? order.startDate.split('T')[0] : new Date().toISOString().split('T')[0],
            endDate: order.endDate ? order.endDate.split('T')[0] : '',
            items: order.items || [],
            materials: order.materials || [],
            notes: order.notes || ''
        });
        setShowWOModal(true);
    };

    // Add Item
    const addItem = () => {
        const newItem: WorkOrderItem = {
            id: `item-${Date.now()}`,
            itemName: '',
            quantity: 1,
            unit: 'قطعة',
            dimensions: { width: 0, length: 0, height: 0 },
            modelCode: '',
            paintColor: '',
            paintCode: '',
            glossPercentage: '',
            veneer: 'NO',
            notes: ''
        };
        setWoForm({ ...woForm, items: [...woForm.items, newItem] });
    };

    // Paste from Excel
    const handlePasteFromExcel = async () => {
        try {
            // Read from clipboard
            const text = await navigator.clipboard.readText();

            if (!text || text.trim() === '') {
                alert(lang === 'ar'
                    ? '⚠️ لم يتم العثور على بيانات. انسخ البيانات من Excel أولاً'
                    : '⚠️ No data found. Copy data from Excel first');
                return;
            }

            // Split into rows
            const rows = text.split('\n').filter(row => row.trim());

            // Convert each row to WorkOrderItem
            const newItems: WorkOrderItem[] = rows.map((row, index) => {
                // Excel uses Tab as separator
                const cols = row.split('\t').map(col => col.trim());

                return {
                    id: `item-${Date.now()}-${index}`,
                    itemName: cols[0] || '',
                    quantity: parseInt(cols[1]) || 1,
                    unit: 'قطعة',
                    dimensions: {
                        width: parseInt(cols[2]) || 0,
                        length: parseInt(cols[3]) || 0,
                        height: parseInt(cols[4]) || 0
                    },
                    modelCode: '',
                    paintColor: '',
                    paintCode: '',
                    glossPercentage: '',
                    veneer: 'NO',
                    notes: ''
                };
            });

            // Filter out completely empty items
            const validItems = newItems.filter(item => item.itemName && item.itemName.trim() !== '');

            if (validItems.length === 0) {
                alert(lang === 'ar'
                    ? '⚠️ لم يتم العثور على عناصر صالحة. تأكد من نسخ البيانات بشكل صحيح'
                    : '⚠️ No valid items found. Make sure to copy data correctly');
                return;
            }

            // Add to existing items
            setWoForm({ ...woForm, items: [...woForm.items, ...validItems] });

            alert(lang === 'ar'
                ? `✅ تم إضافة ${validItems.length} عنصر بنجاح!`
                : `✅ Successfully added ${validItems.length} items!`);

        } catch (error) {
            console.error('Paste error:', error);
            alert(lang === 'ar'
                ? '❌ فشل اللصق. تأكد من نسخ البيانات من Excel أولاً (Ctrl+C)'
                : '❌ Paste failed. Make sure to copy data from Excel first (Ctrl+C)');
        }
    };

    const updateItem = (index: number, field: string, value: any) => {
        const newItems = [...woForm.items];
        if (field.startsWith('dimensions.')) {
            const dimField = field.split('.')[1];
            newItems[index] = {
                ...newItems[index],
                dimensions: { ...newItems[index].dimensions, [dimField]: value }
            };
        } else {
            newItems[index] = { ...newItems[index], [field]: value };
        }
        setWoForm({ ...woForm, items: newItems });
    };

    const removeItem = (index: number) => {
        setWoForm({ ...woForm, items: woForm.items.filter((_, i) => i !== index) });
    };

    // Add Material from Products
    const addMaterial = (productId: string) => {
        const product = products.find(p => p.id === productId);
        if (!product) return;

        const existingIndex = woForm.materials.findIndex(m => m.productId === productId);
        if (existingIndex !== -1) {
            // Update quantity if already exists
            const newMaterials = [...woForm.materials];
            newMaterials[existingIndex].quantity += 1;
            setWoForm({ ...woForm, materials: newMaterials });
        } else {
            // Determine category correctly
            let category: 'wood' | 'accessories' | 'other' = 'other';
            if (product.categoryCode === 'WD') {
                category = 'wood';
            } else if (['HW', 'EB', 'CN', 'TB'].includes(product.categoryCode)) {
                category = 'accessories';
            }

            const newMaterial: MaterialRequest = {
                id: `mat-${Date.now()}`,
                productId: product.id,
                productName: lang === 'ar' ? product.nameAr : product.nameEn,
                quantity: 1,
                unit: product.unit,
                category: category,
                isManual: false
            };
            setWoForm({ ...woForm, materials: [...woForm.materials, newMaterial] });
        }
    };

    // Add Manual Material (not from products database)
    const addManualMaterial = () => {
        const newMaterial: MaterialRequest = {
            id: `mat-${Date.now()}`,
            productName: '',
            quantity: 1,
            unit: 'قطعة',
            category: 'other',
            isManual: true
        };
        setWoForm({ ...woForm, materials: [...woForm.materials, newMaterial] });
    };

    const updateMaterial = (index: number, field: string, value: any) => {
        const newMaterials = [...woForm.materials];
        newMaterials[index] = { ...newMaterials[index], [field]: value };
        setWoForm({ ...woForm, materials: newMaterials });
    };

    // Paste Wood Materials from Excel - Smart Version
    const handlePasteWoodMaterials = async () => {
        try {
            const text = await navigator.clipboard.readText();

            if (!text || text.trim() === '') {
                alert(lang === 'ar'
                    ? '⚠️ لم يتم العثور على بيانات. انسخ البيانات من Excel أولاً'
                    : '⚠️ No data found. Copy data from Excel first');
                return;
            }

            const rows = text.split('\n').filter(row => row.trim());

            // Smart header detection - skip if first row contains common headers
            const headerKeywords = ['material', 'name', 'qty', 'quantity', 'unit', 'width', 'length', 'thickness', 'اسم', 'المادة', 'الكمية', 'الوحدة', 'العرض', 'الطول', 'السمك'];
            let startIndex = 0;

            if (rows.length > 0) {
                const firstRow = rows[0].toLowerCase();
                const hasHeader = headerKeywords.some(keyword => firstRow.includes(keyword.toLowerCase()));
                if (hasHeader) {
                    startIndex = 1; // Skip header row
                    console.log('📋 Header detected and skipped');
                }
            }

            const newMaterials: MaterialRequest[] = [];

            for (let i = startIndex; i < rows.length; i++) {
                const cols = rows[i].split('\t').map(col => col.trim());

                // Skip empty rows
                if (!cols[0] || cols[0] === '') continue;

                // Smart column detection
                let materialName = cols[0] || '';
                let quantity = 1;
                let unit = 'لوح';
                let width = 0;
                let thickness = 0;
                let length = 0;

                // Try to parse quantity (column 1)
                if (cols[1]) {
                    const qtyValue = parseFloat(cols[1]);
                    if (!isNaN(qtyValue)) {
                        quantity = qtyValue;
                    }
                }

                // Smart unit detection (column 2)
                // If column 2 is a number, it's probably width, not unit
                if (cols[2]) {
                    const col2AsNumber = parseFloat(cols[2]);
                    if (isNaN(col2AsNumber)) {
                        // It's text, so it's the unit
                        unit = cols[2];
                        // Check if we have thickness (5 columns: Name|QTY|Unit|W|T|L)
                        if (cols[5] && !isNaN(parseFloat(cols[5]))) {
                            width = parseInt(cols[3]) || 0;
                            thickness = parseInt(cols[4]) || 0;
                            length = parseInt(cols[5]) || 0;
                        } else {
                            // No thickness (4 columns: Name|QTY|Unit|W|L)
                            width = parseInt(cols[3]) || 0;
                            length = parseInt(cols[4]) || 0;
                        }
                    } else {
                        // It's a number, so it's width (no unit column)
                        unit = 'لوح'; // default
                        // Check if we have thickness (4 columns: Name|QTY|W|T|L)
                        if (cols[4] && !isNaN(parseFloat(cols[4]))) {
                            width = col2AsNumber;
                            thickness = parseInt(cols[3]) || 0;
                            length = parseInt(cols[4]) || 0;
                        } else {
                            // No thickness (3 columns: Name|QTY|W|L)
                            width = col2AsNumber;
                            length = parseInt(cols[3]) || 0;
                        }
                    }
                }

                newMaterials.push({
                    id: `mat-wood-${Date.now()}-${i}`,
                    productName: materialName,
                    quantity: quantity,
                    unit: unit,
                    category: 'wood' as const,
                    isManual: true,
                    size: {
                        width: width,
                        length: length
                    },
                    notes: thickness > 0 ? `T: ${thickness}mm` : ''
                });
            }

            if (newMaterials.length === 0) {
                alert(lang === 'ar'
                    ? '⚠️ لم يتم العثور على مواد صالحة'
                    : '⚠️ No valid materials found');
                return;
            }

            setWoForm({ ...woForm, materials: [...woForm.materials, ...newMaterials] });

            alert(lang === 'ar'
                ? `✅ تم إضافة ${newMaterials.length} مادة خشبية!`
                : `✅ Added ${newMaterials.length} wood materials!`);

        } catch (error) {
            console.error('Paste error:', error);
            alert(lang === 'ar'
                ? '❌ فشل اللصق. تأكد من نسخ البيانات من Excel'
                : '❌ Paste failed. Copy data from Excel first');
        }
    };

    // Paste Accessories from Excel - Smart Version
    const handlePasteAccessories = async () => {
        try {
            const text = await navigator.clipboard.readText();

            if (!text || text.trim() === '') {
                alert(lang === 'ar'
                    ? '⚠️ لم يتم العثور على بيانات. انسخ البيانات من Excel أولاً'
                    : '⚠️ No data found. Copy data from Excel first');
                return;
            }

            const rows = text.split('\n').filter(row => row.trim());

            // Smart header detection
            const headerKeywords = ['material', 'name', 'qty', 'quantity', 'notes', 'ملاحظات', 'اسم', 'المادة', 'الكمية'];
            let startIndex = 0;

            if (rows.length > 0) {
                const firstRow = rows[0].toLowerCase();
                const hasHeader = headerKeywords.some(keyword => firstRow.includes(keyword.toLowerCase()));
                if (hasHeader) {
                    startIndex = 1;
                    console.log('📋 Header detected and skipped');
                }
            }

            const newMaterials: MaterialRequest[] = [];

            for (let i = startIndex; i < rows.length; i++) {
                const cols = rows[i].split('\t').map(col => col.trim());

                // Skip empty rows
                if (!cols[0] || cols[0] === '') continue;

                let materialName = cols[0] || '';
                let quantity = 1;
                let notes = '';

                // Parse quantity
                if (cols[1]) {
                    const qtyValue = parseFloat(cols[1]);
                    if (!isNaN(qtyValue)) {
                        quantity = qtyValue;
                    }
                }

                // Notes (column 2 or later)
                if (cols[2]) {
                    notes = cols[2];
                }

                newMaterials.push({
                    id: `mat-acc-${Date.now()}-${i}`,
                    productName: materialName,
                    quantity: quantity,
                    unit: 'قطعة',
                    category: 'accessories' as const,
                    isManual: true,
                    notes: notes
                });
            }

            if (newMaterials.length === 0) {
                alert(lang === 'ar'
                    ? '⚠️ لم يتم العثور على مواد صالحة'
                    : '⚠️ No valid materials found');
                return;
            }

            setWoForm({ ...woForm, materials: [...woForm.materials, ...newMaterials] });

            alert(lang === 'ar'
                ? `✅ تم إضافة ${newMaterials.length} إكسسوار!`
                : `✅ Added ${newMaterials.length} accessories!`);

        } catch (error) {
            console.error('Paste error:', error);
            alert(lang === 'ar'
                ? '❌ فشل اللصق. تأكد من نسخ البيانات من Excel'
                : '❌ Paste failed. Copy data from Excel first');
        }
    };

    const removeMaterial = (index: number) => {
        setWoForm({ ...woForm, materials: woForm.materials.filter((_, i) => i !== index) });
    };

    // Double-click column header to paste values from clipboard
    const handleColumnPaste = async (columnName: string, tableType: 'items' | 'materials') => {
        try {
            const text = await navigator.clipboard.readText();

            if (!text || text.trim() === '') {
                alert(lang === 'ar'
                    ? '⚠️ لم يتم العثور على بيانات في الحافظة'
                    : '⚠️ No data found in clipboard');
                return;
            }

            // Split by newlines to get individual values
            const values = text.split('\n')
                .map(v => v.trim())
                .filter(v => v !== '');

            if (values.length === 0) {
                alert(lang === 'ar'
                    ? '⚠️ لا توجد قيم صالحة'
                    : '⚠️ No valid values');
                return;
            }

            if (tableType === 'items') {
                let newItems = [...woForm.items];

                // Auto-create rows if needed
                const rowsNeeded = values.length;
                const currentRows = newItems.length;

                if (rowsNeeded > currentRows) {
                    const rowsToAdd = rowsNeeded - currentRows;
                    for (let i = 0; i < rowsToAdd; i++) {
                        newItems.push({
                            id: `item-${Date.now()}-${i}`,
                            itemName: '',
                            quantity: 1,
                            unit: 'قطعة',
                            dimensions: { width: 0, length: 0, height: 0 },
                            modelCode: '',
                            paintColor: '',
                            paintCode: '',
                            glossPercentage: '',
                            veneer: 'NO',
                            notes: ''
                        });
                    }
                }

                // Paste values
                values.forEach((value, idx) => {
                    if (idx < newItems.length) {
                        switch (columnName) {
                            case 'itemName':
                                newItems[idx].itemName = value;
                                break;
                            case 'quantity':
                                newItems[idx].quantity = parseInt(value) || newItems[idx].quantity;
                                break;
                            case 'width':
                                newItems[idx].dimensions = { ...newItems[idx].dimensions, width: parseInt(value) || 0 };
                                break;
                            case 'length':
                                newItems[idx].dimensions = { ...newItems[idx].dimensions, length: parseInt(value) || 0 };
                                break;
                            case 'height':
                                newItems[idx].dimensions = { ...newItems[idx].dimensions, height: parseInt(value) || 0 };
                                break;
                            case 'modelCode':
                                newItems[idx].modelCode = value;
                                break;
                            case 'paintColor':
                                newItems[idx].paintColor = value;
                                break;
                            case 'paintCode':
                                newItems[idx].paintCode = value;
                                break;
                            case 'glossPercentage':
                                newItems[idx].glossPercentage = value;
                                break;
                            case 'veneer':
                                newItems[idx].veneer = value;
                                break;
                            case 'notes':
                                newItems[idx].notes = value;
                                break;
                        }
                    }
                });
                setWoForm({ ...woForm, items: newItems });
                alert(lang === 'ar'
                    ? `✅ تم لصق ${values.length} قيمة${rowsNeeded > currentRows ? ` (تم إضافة ${rowsNeeded - currentRows} صف)` : ''}`
                    : `✅ Pasted ${values.length} values${rowsNeeded > currentRows ? ` (added ${rowsNeeded - currentRows} rows)` : ''}`);
            } else if (tableType === 'materials') {
                let newMaterials = [...woForm.materials];

                // Auto-create rows if needed
                const rowsNeeded = values.length;
                const currentRows = newMaterials.length;

                if (rowsNeeded > currentRows) {
                    const rowsToAdd = rowsNeeded - currentRows;
                    for (let i = 0; i < rowsToAdd; i++) {
                        newMaterials.push({
                            id: `mat-${Date.now()}-${i}`,
                            productName: '',
                            quantity: 1,
                            unit: 'لوح',
                            category: 'wood' as const,
                            isManual: true,
                            size: { width: 0, length: 0 }
                        });
                    }
                }

                // Paste values
                values.forEach((value, idx) => {
                    if (idx < newMaterials.length) {
                        switch (columnName) {
                            case 'productName':
                                newMaterials[idx].productName = value;
                                break;
                            case 'quantity':
                                newMaterials[idx].quantity = parseFloat(value) || newMaterials[idx].quantity;
                                break;
                            case 'unit':
                                newMaterials[idx].unit = value;
                                break;
                            case 'width':
                                newMaterials[idx].size = { ...newMaterials[idx].size, width: parseInt(value) || 0 };
                                break;
                            case 'thickness':
                                newMaterials[idx].size = { ...newMaterials[idx].size, thickness: parseInt(value) || 0 };
                                break;
                            case 'length':
                                newMaterials[idx].size = { ...newMaterials[idx].size, length: parseInt(value) || 0 };
                                break;
                            case 'notes':
                                newMaterials[idx].notes = value;
                                break;
                        }
                    }
                });
                setWoForm({ ...woForm, materials: newMaterials });
                alert(lang === 'ar'
                    ? `✅ تم لصق ${values.length} قيمة${rowsNeeded > currentRows ? ` (تم إضافة ${rowsNeeded - currentRows} صف)` : ''}`
                    : `✅ Pasted ${values.length} values${rowsNeeded > currentRows ? ` (added ${rowsNeeded - currentRows} rows)` : ''}`);
            }

        } catch (error) {
            console.error('Column paste error:', error);
            alert(lang === 'ar'
                ? '❌ فشل اللصق. تأكد من نسخ القيم من Excel'
                : '❌ Paste failed. Copy values from Excel first');
        }
    };

    const handleEndDateSuggestion = (days: number) => {
        const date = new Date();
        date.setDate(date.getDate() + days);
        setWoForm(prev => ({ ...prev, endDate: date.toISOString().split('T')[0] }));
    };

    // Save Work Order
    const handleSaveWO = () => {
        // Validation: Check if customer name is filled
        if (!woForm.customerName || woForm.customerName.trim() === '') {
            alert(lang === 'ar'
                ? '⚠️ يرجى إدخال اسم العميل قبل الحفظ'
                : '⚠️ Please enter customer name before saving');
            return;
        }

        // Validation: Check if at least one item has a name
        const hasValidItems = woForm.items.some(item => item.itemName && item.itemName.trim() !== '');

        // Validation: Check if at least one material has a name
        const hasValidMaterials = woForm.materials.some(mat => mat.productName && mat.productName.trim() !== '');

        if (!hasValidItems && !hasValidMaterials) {
            alert(lang === 'ar'
                ? '⚠️ يرجى إضافة عنصر واحد على الأقل أو مادة واحدة قبل الحفظ'
                : '⚠️ Please add at least one item or material before saving');
            return;
        }

        // Filter out empty items and materials before saving
        const validItems = woForm.items.filter(item => item.itemName && item.itemName.trim() !== '');
        const validMaterials = woForm.materials.filter(mat => mat.productName && mat.productName.trim() !== '');

        if (editingOrderId) {
            // Update existing order - find the original order to preserve all fields
            const originalOrder = workOrders.find(wo => wo.id === editingOrderId);
            if (originalOrder) {
                // Merge form data with original order data to preserve all fields
                onUpdateWorkOrder(editingOrderId, {
                    ...originalOrder,  // Keep all original fields
                    ...woForm,         // Override with form data
